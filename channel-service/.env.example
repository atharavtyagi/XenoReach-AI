# Channel Service Environment Variables

# Server
NODE_ENV=development
PORT=5001

# CRM Backend callback URL
CRM_CALLBACK_URL=http://localhost:5000/api/analytics/callback

# Simulation settings (ms)
# How long between delivery events
MIN_DELIVERY_DELAY_MS=500
MAX_DELIVERY_DELAY_MS=3500

# Channel delivery rates (0-1)
EMAIL_DELIVERY_RATE=0.88
SMS_DELIVERY_RATE=0.94
WHATSAPP_DELIVERY_RATE=0.96
PUSH_DELIVERY_RATE=0.82
